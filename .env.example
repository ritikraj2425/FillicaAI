# ==============================================================================
# FILLICA AI - ENVIRONMENT VARIABLES EXAMPLE
# ==============================================================================
# Copy this file to:
# 1. backend/.env (for the API server)
# 2. .env.local (in the root, for the Desktop App)
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. BACKEND SECRETS (Place these in backend/.env)
# ------------------------------------------------------------------------------

# --- Database ---
# Your MongoDB connection string
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/database

# --- AWS S3 (For Resume Storage) ---
# Used to store and retrieve user resumes
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_BUCKET_NAME=your_bucket_name
AWS_REGION=eu-north-1
AWS_S3_PREFIX=uploads/

# --- Google OAuth ---
# Required for user login via Google
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# --- Backend Configuration ---
# The URL where your backend is hosted
BACKEND_URL=http://localhost:3001
PORT=3001
NODE_ENV=development

# --- Security ---
# Secret strings for signing sessions and JWT tokens
SESSION_SECRET=a_long_random_string_here
JWT_SECRET=another_random_string_here
JWT_EXPIRY=7d

# --- Frontend / App Context ---
# URL of your frontend (for CORS and redirects)
FRONTEND_URL=http://localhost:3000


# ------------------------------------------------------------------------------
# 2. DESKTOP APP CONFIG (Place these in .env.local in the root)
# ------------------------------------------------------------------------------

# The app needs to know where the live backend API is
# For local development: http://localhost:3001
# For production: https://your-backend.vercel.app
REACT_APP_BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
