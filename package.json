{
  "name": "fillica-desktop",
  "version": "1.0.7",
  "description": "Fillica AI - Job Application Automation Desktop App",
  "main": "out/main/index.js",
  "homepage": "./",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run build:frontend && electron-vite build",
    "preview": "electron-vite preview",
    "pack": "electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder -m",
    "dist:win": "npm run build && electron-builder -w",
    "build:frontend": "cd frontend && npm run build",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@google/genai": "^1.50.1",
    "cheerio": "^1.2.0",
    "dotenv": "^16.3.1",
    "electron-updater": "^6.8.3",
    "openai": "^6.34.0",
    "playwright": "^1.40.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "electron": "^29.0.0",
    "electron-builder": "^24.6.4",
    "electron-vite": "^2.0.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.fillica.app",
    "productName": "Fillica",
    "icon": "frontend/public/logo.png",
    "directories": {
      "buildResources": "assets"
    },
    "files": [
      "out/**/*",
      "frontend/out/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "ritikraj2425",
      "repo": "FillicaAI"
    },
    "mac": {
      "icon": "frontend/public/logo.png",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "icon": "frontend/public/logo.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}